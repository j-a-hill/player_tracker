# Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Merchant Bot Token (separate bot for merchant system)
# Get this from https://discord.com/developers/applications
MERCHANT_BOT_TOKEN=your_merchant_bot_token_here

# Timekeeper Bot Token (separate bot for time tracking)
# Get this from https://discord.com/developers/applications
TIMEKEEPER_BOT_TOKEN=your_timekeeper_bot_token_here

# Inn Bot Token (separate bot for inn management)
# Get this from https://discord.com/developers/applications
INN_BOT_TOKEN=your_inn_bot_token_here

# Google Sheets ID
# The ID from your Google Sheet URL
# https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# GM Role ID (optional)
# Discord role ID that has GM permissions
GM_ROLE_ID=your_gm_role_id_here

# Notification Channel ID (optional, for weekly timekeeper notifications)
# Discord channel ID where weekly notifications should be sent
NOTIFICATION_CHANNEL_ID=your_notification_channel_id_here
